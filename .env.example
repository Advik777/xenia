# ============================================================================
#  Veil / Doxxing Shield — BACKEND environment
#  Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#  Every secret below is server-side only and must never reach the browser.
# ============================================================================


# --- Server ---------------------------------------------------------------
PORT=4000
NODE_ENV=development


# Comma-separated list of origins allowed to call this API (the frontend URLs).
# Production (Vercel): https://xyrisvision.vercel.app
# Include localhost entries when testing locally against a deployed API.
CORS_ALLOWED_ORIGINS=https://xyrisvision.vercel.app,http://localhost:3000,http://localhost:5500,http://127.0.0.1:3000,http://127.0.0.1:5500


# --- Supabase -------------------------------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Anon key — used only to verify a caller's JWT (not to bypass RLS).
SUPABASE_ANON_KEY=
# Service-role key — bypasses RLS. The backend is the ONLY place this exists.
SUPABASE_SERVICE_ROLE_KEY=


# --- Vision providers -----------------------------------------------------
# OpenRouter key that bills all paid ("credit") and admin scans.
CREDIT_API_KEY_OPENROUTER=
# Single upstream model served to credit users and the admin.
MODEL_API_USERS_OPENROUTER=anthropic/claude-opus-4.8:extra


# --- Stripe ---------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time price for the $10.00 credit pack (create in the Stripe dashboard).
STRIPE_PRICE_ID=


# USD of virtual credits granted per successful purchase (user pays more; the
# difference is the platform fee). Must match the value advertised in the UI.
CREDITS_GRANTED_USD=5.00


# --- App metadata ---------------------------------------------------------
# Public URL of the FRONTEND (Vercel) — used for Stripe success/cancel redirects.
APP_URL=https://xyrisvision.vercel.app
SUPPORT_EMAIL=aegiswheil@gmail.com


# Admin Google account — unlimited free access to paid vision model.
ADMIN_EMAIL=
